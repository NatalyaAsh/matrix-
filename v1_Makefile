.PHONY: all test s21_matrix.a clang clean cppcheck rebuild gcov_report leaks

NAME_SYS = $(shell uname -s)

ifeq ($(NAME_SYS), Darwin)
  FLAGS_CHECK = -lcheck -lm -lpthread
	OPEN = open
else ifeq ($(NAME_SYS), Linux)
	FLAGS_CHECK = -lcheck -lsubunit -lm -lpthread -lrt
	OPEN = xdg-open
endif

FLAG = -Wall -Wextra -Werror -std=gnu11
FLAG_TEST = -fprofile-arcs -ftest-coverage -pedantic -std=gnu11
# LINUX=-lsubunit -lrt
LIBS=-lcheck -lm -lpthread
CC=gcc

TARGET_A = s21_matrix.a
TARGET_C = internal/funcs/*.c internal/utils/*.c
TARGET_O = *.o
TARGET_TEST = unit_test

all: clean $(TARGET_A)

clean: 
	@echo "clean objects..."
	rm -rf *.o
	@echo "clean library..."
	rm -rf *.a
	@echo "clean test..."
	rm -rf *.gcda
	rm -rf *.gcno
	rm -rf *.info
	rm -rf test
	rm -rf report
	rm -rf *.dSYM
	@echo "clean unit test..."	
	rm -rf unit_test	

$(TARGET_A):
	@$(CC) -c $(FLAGS) $(TARGET_C)
	ar rcs $(TARGET_A) $(TARGET_O)
	ranlib $(TARGET_A) 
	@echo "s21_matrix.a compiled successfully"

test: clean s21_matrix.a
	@$(CC) $(FLAGS) $(FLAGS_TEST) -g tests/*.c $(TARGET_A) -o $(TARGET_TEST) $(FLAGS_CHECK) -lgcov
	@echo "running tests..."
	@./$(TARGET_TEST)

